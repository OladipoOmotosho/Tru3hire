# TrueHire Backend — direct dependencies (source of truth)
#
# This is the human-edited list of DIRECT dependencies. The pinned, installable
# set lives in requirements.txt (what the Dockerfile installs). When you change
# a dependency here, update the matching pin in requirements.txt.
# CI (Python 3.11) verifies the pinned set installs AND that the committed
# scam-classifier model still deserializes under it.

# Web framework
fastapi
uvicorn[standard]
pydantic

# Machine learning (model-load critical — keep pins in sync with the trained model)
scikit-learn
joblib
numpy
scipy
pandas

# File handling
python-multipart

# Resume parsing
pdfplumber
pypdf
python-docx

# HTTP client for external APIs
httpx

# Environment variables
python-dotenv

# Fuzzy string matching for company verification
rapidfuzz

# HTML parsing for URL scraping
beautifulsoup4
lxml

# PostgreSQL driver
psycopg2-binary

# Semantic embeddings (Gemini)
google-genai

# JWT verification for Clerk auth (imports as 'jwt')
pyjwt[crypto]

# Rate limiting
slowapi
