# ============================================
# ML / Data Science
# ============================================

# Model files (binaries - don't commit large files)
*.joblib
*.pkl
*.pickle
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.pb
*.ckpt
*.safetensors
models/
**/models/

# Data files (keep out of repo)
*.csv
*.parquet
*.arrow
*.feather
data/*.csv
data/*.json

# Except specific data files you want to track
!data/.gitkeep
!**/requirements.txt

